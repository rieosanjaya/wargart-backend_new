APP_NAME=WargaRT
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://192.168.0.105:8000
APP_TIMEZONE=Asia/Jakarta
LOG_LEVEL=info
JWT_SECRET=

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=wargart
DB_USERNAME=wargart
DB_PASSWORD=

AUTH_ACCESS_TTL_MINUTES=15
AUTH_REFRESH_TTL_DAYS=30
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_PROVIDER=log
OTP_FIXED_CODE=123456
OTP_LOG_ALLOW_PRODUCTION=false
# Provider log hanya boleh dipakai pada local/testing.
# Untuk uji Railway privat, boleh set OTP_LOG_ALLOW_PRODUCTION=true sementara.
# Untuk go-live publik, gunakan adapter OTP produksi.

# WAHA WhatsApp Web API. Pakai OTP_PROVIDER=waha.
# Cocok untuk cepat jalan, tetapi pastikan WAHA dikelola di server milik sendiri.
WAHA_BASE_URL=
WAHA_SESSION=default
WAHA_API_KEY=
WAHA_SEND_TEXT_PATH=/api/sendText
OTP_WHATSAPP_MESSAGE="Kode OTP WargaRT Anda: {code}. Berlaku 5 menit. Jangan berikan kode ini kepada siapa pun."

# WhatsApp Cloud API resmi Meta. Pakai OTP_PROVIDER=whatsapp_cloud.
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_GRAPH_VERSION=v21.0
WHATSAPP_OTP_TEMPLATE_NAME=wargart_otp
WHATSAPP_OTP_TEMPLATE_LANGUAGE=id
WHATSAPP_OTP_TEMPLATE_HAS_BUTTON=true

# SMS Twilio. Pakai OTP_PROVIDER=sms_twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
OTP_SMS_MESSAGE="Kode OTP WargaRT Anda: {code}. Berlaku 5 menit."

FILESYSTEM_DISK=local
APP_STORAGE_ROOT=/data
QUEUE_CONNECTION=database
PORT=8000

# Hanya untuk seeding non-production. Ganti sebelum menjalankan DatabaseSeeder.
SEED_DEMO_DATA=false
DEMO_ADMIN_PASSWORD=AdminDemo@12345
DEMO_ADMIN_PHONE=+6281234500099
DEMO_CITIZEN_PASSWORD=rio123
